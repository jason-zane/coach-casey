# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Strava
# Modes:
#   live  — full OAuth flow. Requires STRAVA_CLIENT_ID + STRAVA_CLIENT_SECRET
#           and the app's Authorization Callback Domain matching the deploy URL.
#   dev   — single-user bootstrap from pasted tokens (no OAuth, no callback
#           domain needed). Uses STRAVA_DEV_ACCESS_TOKEN + STRAVA_DEV_REFRESH_TOKEN.
#           Get both from https://www.strava.com/settings/api (My API Application).
#   mock  — canned 10-week fixture. No Strava call. Default if unset.
STRAVA_MODE=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_DEV_ACCESS_TOKEN=
STRAVA_DEV_REFRESH_TOKEN=
STRAVA_DEV_EXPIRES_AT=
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Stripe (test mode keys initially)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Langfuse
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# Resend
RESEND_API_KEY=

# App config
NEXT_PUBLIC_APP_URL=
NODE_ENV=
LLM_MODE=  # 'real' | 'mock' — see engineering-foundation.md §9

# Cron authorization. Vercel sets `Authorization: Bearer $CRON_SECRET` on
# scheduled invocations of routes in vercel.json's `crons` array. Generate
# with e.g. `openssl rand -hex 32`. Required in production.
CRON_SECRET=

# Web Push (VAPID). Generate once with:
#   npx web-push generate-vapid-keys
# Paste the resulting keys here (and into Vercel env). The public key is
# duplicated in NEXT_PUBLIC_VAPID_PUBLIC_KEY because the browser-side
# subscribe call needs it. VAPID_SUBJECT must be a `mailto:` URL the push
# service can use to contact you.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:hello@coachcasey.example
